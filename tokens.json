{
  "$description": "Machine source-of-truth for the language-agent design system (W3C DTCG format). HUMAN mirror: DESIGN.md §0. FIGMA mirror: the CORE library's variable collections. Three tiers — `primitive` (raw values), `semantic` (role aliases; what frames/components bind to, never a primitive directly), `locale` (per-language deltas → the Figma `Locale` collection modes ar|zh). Only properties that genuinely differ by script live in `locale`; ~90% of the system is script-neutral and lives once in primitive+semantic. Rationale + migration: docs/decisions/design-system-inheritance.md. NOTE: `direction` is recorded for code-gen only — Figma has no direction variable; RTL/LTR is structural (ADR §1.4).",

  "primitive": {
    "color": {
      "$type": "color",
      "teal-700": { "$value": "#0f766e" },
      "teal-800": { "$value": "#0b5a54" },
      "teal-200": { "$value": "#a9c6c2" },
      "teal-wash": { "$value": "#dcebe8" },
      "gold-600": { "$value": "#b8860b" },
      "gold-wash": { "$value": "#f6ecd2" },
      "amber-500": { "$value": "#c08a2e" },
      "sage-600": { "$value": "#4f7a52" },
      "terracotta-500": { "$value": "#b5654a" },
      "ink-900": { "$value": "#1a1612" },
      "ink-800": { "$value": "#262019" },
      "warmgrey-700": { "$value": "#574f45" },
      "warmgrey-600": { "$value": "#8a8275" },
      "warmgrey-500": { "$value": "#b4ac9d" },
      "warmgrey-400": { "$value": "#a79e8e" },
      "paper-50": { "$value": "#fbf9f4" },
      "paper-100": { "$value": "#f3efe6" },
      "paper-200": { "$value": "#ece6d9" },
      "hairline": { "$value": "#e4ddcd" },
      "hairline-soft": { "$value": "#efe9dc" },
      "white": { "$value": "#ffffff" },
      "offwhite": { "$value": "#f7f3ea" }
    },
    "space": {
      "$type": "dimension",
      "xxs": { "$value": "4px" },
      "xs": { "$value": "8px" },
      "sm": { "$value": "12px" },
      "base": { "$value": "16px" },
      "md": { "$value": "20px" },
      "lg": { "$value": "24px" },
      "xl": { "$value": "32px" },
      "xxl": { "$value": "48px" },
      "section": { "$value": "80px" }
    },
    "radius": {
      "$type": "dimension",
      "none": { "$value": "0px" },
      "xs": { "$value": "4px" },
      "sm": { "$value": "8px" },
      "md": { "$value": "12px" },
      "lg": { "$value": "16px" },
      "xl": { "$value": "22px" },
      "pill": { "$value": "100px" },
      "full": { "$value": "9999px" }
    },
    "font-size": {
      "$type": "dimension",
      "$description": "Script-neutral size scale. Subject (CJK/Arabic) sizes run ~10–15% larger than their Latin counterparts per DESIGN.md §Typography; the named ramp composes these with a locale font-family.",
      "12": { "$value": "12px" },
      "13": { "$value": "13px" },
      "14": { "$value": "14px" },
      "15": { "$value": "15px" },
      "16": { "$value": "16px" },
      "18": { "$value": "18px" },
      "22": { "$value": "22px" },
      "24": { "$value": "24px" },
      "25": { "$value": "25px" },
      "27": { "$value": "27px" },
      "40": { "$value": "40px" }
    },
    "font-weight": {
      "$type": "fontWeight",
      "regular": { "$value": 400 },
      "medium": { "$value": 500 },
      "semibold": { "$value": 600 }
    },
    "line-height": {
      "$type": "number",
      "tight": { "$value": 1.15 },
      "title": { "$value": 1.25 },
      "snug": { "$value": 1.4 },
      "body": { "$value": 1.55 },
      "subject-md": { "$value": 1.85 },
      "subject-token": { "$value": 1.9 }
    },
    "font-family": {
      "$type": "fontFamily",
      "$description": "Raw families. The SUBJECT (reading) family is locale-bound — see `locale.*.font.subject-family`. The UI and mono families are shared across all locales.",
      "ui": { "$value": "Inter" },
      "mono": { "$value": "JetBrains Mono" }
    },
    "duration": {
      "$type": "duration",
      "fast": { "$value": "120ms" },
      "base": { "$value": "200ms" },
      "slow": { "$value": "320ms" },
      "fade-label": { "$value": "600ms" },
      "token-morph": { "$value": "230ms" }
    },
    "easing": {
      "$type": "cubicBezier",
      "standard": { "$value": [0.2, 0, 0, 1] },
      "emphasized": { "$value": [0.3, 0, 0, 1] },
      "spring": { "$value": [0.2, 0.9, 0.3, 1.2] }
    },
    "shadow": {
      "$type": "shadow",
      "$description": "The single soft-card tier — only the click-word popover floats (DESIGN.md §Elevation).",
      "soft-card": { "$value": { "color": "#1a1612", "alpha": 0.12, "offsetX": "0px", "offsetY": "8px", "blur": "24px", "spread": "0px" } }
    }
  },

  "semantic": {
    "$description": "Role aliases of primitives — the layer both Figma files lack today. Frames and components bind to THESE; never to a primitive directly. Multiple roles aliasing one primitive (e.g. primary + status-learning → teal-700) is the point: a token fix or a future dark mode lands in this gap without touching a frame.",
    "color": {
      "$type": "color",
      "primary": { "$value": "{primitive.color.teal-700}" },
      "primary-active": { "$value": "{primitive.color.teal-800}" },
      "primary-disabled": { "$value": "{primitive.color.teal-200}" },
      "accent-gold": { "$value": "{primitive.color.gold-600}" },
      "ink": { "$value": "{primitive.color.ink-900}" },
      "body": { "$value": "{primitive.color.warmgrey-700}" },
      "english-recede": { "$value": "{primitive.color.warmgrey-400}" },
      "muted": { "$value": "{primitive.color.warmgrey-600}" },
      "muted-soft": { "$value": "{primitive.color.warmgrey-500}" },
      "on-primary": { "$value": "{primitive.color.white}" },
      "on-dark": { "$value": "{primitive.color.offwhite}" },
      "on-dark-soft": { "$value": "{primitive.color.warmgrey-500}" },
      "canvas": { "$value": "{primitive.color.paper-50}" },
      "surface-soft": { "$value": "{primitive.color.paper-100}" },
      "surface-card": { "$value": "{primitive.color.white}" },
      "surface-strong": { "$value": "{primitive.color.paper-200}" },
      "surface-dark": { "$value": "{primitive.color.ink-900}" },
      "surface-dark-elevated": { "$value": "{primitive.color.ink-800}" },
      "hairline": { "$value": "{primitive.color.hairline}" },
      "hairline-soft": { "$value": "{primitive.color.hairline-soft}" },
      "status-new": { "$value": "{primitive.color.gold-600}" },
      "status-new-bg": { "$value": "{primitive.color.gold-wash}" },
      "status-learning": { "$value": "{primitive.color.teal-700}" },
      "status-learning-bg": { "$value": "{primitive.color.teal-wash}" },
      "status-known": { "$value": "{primitive.color.ink-900}" },
      "correction-add": { "$value": "{primitive.color.sage-600}" },
      "correction-remove": { "$value": "{primitive.color.terracotta-500}" },
      "confidence-uncertain": { "$value": "{primitive.color.amber-500}" }
    },
    "typography": {
      "$type": "typography",
      "$description": "Named ramp styles compose a LOCALE subject family with script-neutral size/weight/line-height primitives. Only a representative set is enumerated; the remaining DESIGN.md §0 ramp rows follow the same pattern. The `locale.font.*` and `locale.subject-leading` references resolve per the active Locale mode.",
      "subject-reading-lg": { "$value": { "fontFamily": "{locale.font.subject-family}", "fontSize": "{primitive.font-size.27}", "fontWeight": "{primitive.font-weight.regular}", "lineHeight": "{locale.subject-leading}" }, "$description": "The conversation-spine hero (DESIGN.md §0 arabic-reading-lg, 27/1.95). Line-height binds to the LOCALE leading — 1.95 (ar, ḥarakāt clearance) / 1.6 (zh, ruby band) — exercising the Tier-3 delta." },
      "subject-reading-md": { "$value": { "fontFamily": "{locale.font.subject-family}", "fontSize": "{primitive.font-size.22}", "fontWeight": "{primitive.font-weight.regular}", "lineHeight": "{primitive.line-height.subject-md}" } },
      "subject-token": { "$value": { "fontFamily": "{locale.font.subject-family}", "fontSize": "{primitive.font-size.25}", "fontWeight": "{primitive.font-weight.regular}", "lineHeight": "{primitive.line-height.subject-token}" } },
      "annotation": { "$value": { "fontFamily": "{locale.font.annotation-family}", "fontSize": "{primitive.font-size.13}", "fontWeight": "{primitive.font-weight.medium}", "lineHeight": "{primitive.line-height.snug}" } },
      "ui-title-lg": { "$value": { "fontFamily": "{primitive.font-family.ui}", "fontSize": "{primitive.font-size.24}", "fontWeight": "{primitive.font-weight.semibold}", "lineHeight": "{primitive.line-height.title}" } },
      "ui-body": { "$value": { "fontFamily": "{primitive.font-family.ui}", "fontSize": "{primitive.font-size.16}", "fontWeight": "{primitive.font-weight.regular}", "lineHeight": "{primitive.line-height.body}" } },
      "ui-label": { "$value": { "fontFamily": "{primitive.font-family.ui}", "fontSize": "{primitive.font-size.12}", "fontWeight": "{primitive.font-weight.semibold}", "lineHeight": "{primitive.line-height.snug}" } }
    }
  },

  "locale": {
    "$description": "Per-language deltas → the Figma `Locale` variable collection, ONE mode per language (ar | zh). Each token below is ONE variable with per-mode values (mirroring the Figma CORE library exactly): `$value` is the default (ar) resolution and `$extensions.mode` carries every mode. Components and `semantic.typography` bind to these, so flipping the active Locale mode re-resolves them. Only properties that genuinely differ by script live here; ~90% of the system is shared in primitive+semantic. Adding a language = add a mode key to each token (~5–8 values) + 0–3 leaf components + a direction decision.",
    "font": {
      "subject-family": { "$type": "fontFamily", "$value": "Amiri", "$extensions": { "mode": { "ar": "Amiri", "zh": "Noto Serif TC" } } },
      "annotation-family": { "$type": "fontFamily", "$value": "JetBrains Mono", "$extensions": { "mode": { "ar": "JetBrains Mono", "zh": "JetBrains Mono" } } }
    },
    "numeral-system": { "$type": "string", "$value": "arab", "$extensions": { "mode": { "ar": "arab", "zh": "latn" } }, "$description": "ar = Eastern Arabic-Indic ٠-٩ ; zh = Western 0-9." },
    "direction": { "$type": "string", "$value": "rtl", "$description": "Structural — NOT a Figma variable (ADR §1.4); RTL/LTR is handled by components, recorded here for code-gen only.", "$extensions": { "mode": { "ar": "rtl", "zh": "ltr" } } },
    "subject-leading": { "$type": "number", "$value": 1.95, "$description": "The hero reading line-height — locale-dependent (Arabic 1.95 for ḥarakāt clearance; Chinese 1.6 for the pinyin-ruby band). Referenced by `semantic.typography.subject-reading-lg`; in Figma it is the `Locale/subject-leading` variable resolving per mode.", "$extensions": { "mode": { "ar": 1.95, "zh": 1.6 } } }
  }
}
